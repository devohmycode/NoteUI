<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="NoteUI.NoteWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Note">

    <Grid x:Name="RootGrid" KeyDown="RootGrid_KeyDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Title bar (colored) -->
        <Grid x:Name="TitleBarGrid" Grid.Row="0" Height="40" Padding="4,0">
            <Grid x:Name="DragBar" Background="Transparent"
                  PointerPressed="DragBar_PointerPressed"
                  PointerMoved="DragBar_PointerMoved"
                  PointerReleased="DragBar_PointerReleased"/>

            <Button x:Name="MenuButton" HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Background="Transparent" BorderThickness="0"
                    Padding="8,6" Click="Menu_Click"
                    PointerEntered="AnimatedButton_PointerEntered"
                    PointerExited="AnimatedButton_PointerExited">
                <FontIcon x:Name="MenuIcon" Glyph="&#xE712;" FontSize="14" Foreground="Black"/>
            </Button>

            <!-- Inline editable title -->
            <TextBlock x:Name="TitleText"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="13" Foreground="Black"
                       IsHitTestVisible="True"
                       Tapped="TitleText_Tapped"
                       TextTrimming="CharacterEllipsis" MaxWidth="200"/>
            <TextBox x:Name="TitleEditBox"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     FontSize="13" Visibility="Collapsed"
                     MinWidth="120" MaxWidth="200"
                     Background="Transparent" BorderThickness="0"
                     Padding="6,4" TextAlignment="Center"
                     LostFocus="TitleEditBox_LostFocus"
                     KeyDown="TitleEditBox_KeyDown"/>

            <FontIcon x:Name="AttachIcon" Glyph="&#xE723;" FontSize="10"
                     Foreground="Black" Opacity="0.5" Visibility="Collapsed"
                     HorizontalAlignment="Left" VerticalAlignment="Center"
                     Margin="40,0,0,0"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        VerticalAlignment="Center" Spacing="0">
                <Button x:Name="LockButton" Background="Transparent" BorderThickness="0"
                        Padding="8,6" Click="Lock_Click"
                        PointerEntered="AnimatedButton_PointerEntered"
                        PointerExited="AnimatedButton_PointerExited">
                    <FontIcon x:Name="LockIcon" Glyph="&#xE72E;" FontSize="12" Foreground="Black"/>
                </Button>
                <Button x:Name="CompactButton" Background="Transparent" BorderThickness="0"
                        Padding="8,6" Click="Compact_Click"
                        PointerEntered="AnimatedButton_PointerEntered"
                        PointerExited="AnimatedButton_PointerExited">
                    <FontIcon x:Name="CompactIcon" Glyph="&#xE70E;" FontSize="12" Foreground="Black"/>
                </Button>
                <Button x:Name="PinButton"
                        Background="Transparent" BorderThickness="0"
                        Padding="8,6" Click="Pin_Click"
                        PointerEntered="AnimatedButton_PointerEntered"
                        PointerExited="AnimatedButton_PointerExited">
                    <FontIcon x:Name="PinIcon" Glyph="&#xE718;" FontSize="12" Foreground="Black"/>
                </Button>
                <Button x:Name="NoteCloseButton" Background="Transparent" BorderThickness="0"
                        Padding="8,6" Click="Close_Click"
                        PointerEntered="AnimatedButton_PointerEntered"
                        PointerExited="AnimatedButton_PointerExited">
                    <FontIcon x:Name="CloseIcon" Glyph="&#xE711;" FontSize="12" Foreground="Black"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Row 1: Rich text editor (notes) -->
        <RichEditBox x:Name="NoteEditor" Grid.Row="1"
                     AcceptsReturn="True"
                     BorderThickness="0"
                     Background="Transparent"
                     CornerRadius="0"
                     Padding="12,4"
                     AllowDrop="True"
                     DragOver="NoteEditor_DragOver"
                     Drop="NoteEditor_Drop"
                     TextChanged="NoteEditor_TextChanged">
            <RichEditBox.Resources>
                <SolidColorBrush x:Key="TextControlBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent"/>
                <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent"/>
                <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent"/>
                <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent"/>
                <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent"/>
            </RichEditBox.Resources>
        </RichEditBox>

        <!-- Row 1: Task list (tasklists) -->
        <ScrollViewer x:Name="TaskListScroll" Grid.Row="1" Visibility="Collapsed"
                      VerticalScrollBarVisibility="Auto" Padding="8,4,8,4"
                      >
            <StackPanel Spacing="0">
                <StackPanel x:Name="TaskListPanel" Spacing="2">
                    <!-- Tasks added dynamically -->
                </StackPanel>

                <!-- Free-form text area below tasks -->
                <RichEditBox x:Name="TaskNoteEditor"
                             AcceptsReturn="True"
                             BorderThickness="0"
                             Background="Transparent"
                             CornerRadius="0"
                             Padding="12,8"
                             MinHeight="80"
                             AllowDrop="True"
                             DragOver="NoteEditor_DragOver"
                             Drop="NoteEditor_Drop"
                             TextChanged="TaskNoteEditor_TextChanged">
                    <RichEditBox.Resources>
                        <SolidColorBrush x:Key="TextControlBackground" Color="Transparent"/>
                        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent"/>
                        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent"/>
                        <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent"/>
                        <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent"/>
                        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent"/>
                    </RichEditBox.Resources>
                </RichEditBox>
            </StackPanel>
        </ScrollViewer>

        <!-- Row 2: Status bar with Format (left) and Couleur (right) -->
        <Grid x:Name="StatusBar" Grid.Row="2" Padding="4,2"
              BorderThickness="0,1,0,0"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="FormatButton" Grid.Column="0"
                    Background="Transparent" BorderThickness="0"
                    Padding="10,6" Click="Format_Click"
                    PointerEntered="AnimatedButton_PointerEntered"
                    PointerExited="AnimatedButton_PointerExited">
                <FontIcon x:Name="FormatIcon" Glyph="&#xE8D2;" FontSize="12"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </Button>

            <Button x:Name="VoiceButton" Grid.Column="1"
                    Background="Transparent" BorderThickness="0"
                    Padding="10,6" Click="Voice_Click"
                    PointerEntered="AnimatedButton_PointerEntered"
                    PointerExited="AnimatedButton_PointerExited">
                <FontIcon x:Name="VoiceIcon" Glyph="&#xE720;" FontSize="12"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </Button>

            <Button x:Name="AiButton" Grid.Column="2"
                    Background="Transparent" BorderThickness="0"
                    Padding="10,6" Click="AiMenu_Click"
                    PointerEntered="AnimatedButton_PointerEntered"
                    PointerExited="AnimatedButton_PointerExited">
                <FontIcon x:Name="AiIcon" Glyph="&#xE99A;" FontSize="12"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </Button>

            <Button x:Name="ColorButton" Grid.Column="4"
                    Background="Transparent" BorderThickness="0"
                    Padding="10,6" Click="Color_Click"
                    PointerEntered="AnimatedButton_PointerEntered"
                    PointerExited="AnimatedButton_PointerExited">
                <Ellipse x:Name="ColorIndicator" Width="12" Height="12"/>
            </Button>
        </Grid>
    </Grid>
</Window>
