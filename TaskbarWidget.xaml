<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="NoteUI.TaskbarWidget"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="NoteUI Widget">
    <Grid x:Name="RootGrid" Background="Transparent">
        <StackPanel x:Name="ButtonPanel" Orientation="Horizontal"
                    VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="0">
            <Button x:Name="ClipboardButton"
                    Padding="4" MinWidth="28" MinHeight="26" MaxWidth="28" MaxHeight="26"
                    Background="Transparent" BorderThickness="0" CornerRadius="4"
                    Click="ClipboardButton_Click">
                <FontIcon Glyph="&#xE16F;" FontSize="13"/>
            </Button>
            <Button x:Name="FavoritesButton"
                    Padding="4" MinWidth="28" MinHeight="26" MaxWidth="28" MaxHeight="26"
                    Background="Transparent" BorderThickness="0" CornerRadius="4"
                    Click="FavoritesButton_Click">
                <FontIcon Glyph="&#xE734;" FontSize="13"/>
            </Button>
        </StackPanel>
    </Grid>
</Window>
