<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="NoteUI.VoiceNoteWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Note audio">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Grid x:Name="TitleBar" Grid.Row="0" Height="40" Padding="4,0">
            <Grid x:Name="DragBar" Background="Transparent"
                  PointerPressed="DragBar_PointerPressed"
                  PointerMoved="DragBar_PointerMoved"
                  PointerReleased="DragBar_PointerReleased"/>

            <Button x:Name="SettingsButton" HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Background="Transparent" BorderThickness="0"
                    Padding="8,6" Click="Settings_Click"
                    Visibility="Collapsed">
                <FontIcon Glyph="&#xE713;" FontSize="14"/>
            </Button>

            <TextBlock x:Name="TitleBarText"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="13"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        VerticalAlignment="Center" Spacing="0">
                <Button x:Name="PinButton" Background="Transparent" BorderThickness="0"
                        Padding="8,6" Click="Pin_Click">
                    <FontIcon x:Name="PinIcon" Glyph="&#xE718;" FontSize="12"/>
                </Button>
                <Button x:Name="VoiceCloseButton" Background="Transparent" BorderThickness="0"
                        Padding="8,6" Click="Close_Click">
                    <FontIcon Glyph="&#xE711;" FontSize="12"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Page 0: Language selection -->
        <Grid x:Name="LanguageSelectionPage" Grid.Row="1" Padding="16,8"
              VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel Spacing="20" MaxWidth="320">
                <TextBlock x:Name="ChooseLanguageLabel"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           HorizontalAlignment="Center"/>

                <StackPanel Spacing="8">
                    <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Padding="16,14" Click="LanguageFr_Click">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="&#x1F1EB;&#x1F1F7;" FontSize="24" VerticalAlignment="Center"/>
                            <StackPanel Spacing="2" VerticalAlignment="Center">
                                <TextBlock x:Name="FrenchLabel"/>
                                <TextBlock Text="Vosk &amp; Whisper"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>
                    <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Padding="16,14" Click="LanguageEn_Click">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="&#x1F1EC;&#x1F1E7;" FontSize="24" VerticalAlignment="Center"/>
                            <StackPanel Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="English"/>
                                <TextBlock Text="Vosk &amp; Whisper"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Page 1: Model selection -->
        <ScrollViewer x:Name="ModelSelectionPage" Grid.Row="1" Padding="16,8"
                      Visibility="Collapsed">
            <StackPanel Spacing="12">
                <TextBlock x:Name="ModelSelectionTitle"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           Margin="0,0,0,4"/>

                <ListView x:Name="FilteredModelList"
                          SelectionMode="None"
                          IsItemClickEnabled="True"
                          ItemClick="ModelList_ItemClick">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="8,10" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <FontIcon Grid.Column="0" Glyph="&#xE720;" FontSize="18"
                                          VerticalAlignment="Center"
                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="{Binding Name}"/>
                                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                        <Run Text="{Binding EngineName}"/>
                                        <Run Text=" &#x2014; "/>
                                        <Run Text="{Binding SizeMB}"/>
                                        <Run Text=" MB"/>
                                    </TextBlock>
                                </StackPanel>

                                <TextBlock Grid.Column="2"
                                           Text="&#x2713;"
                                           FontSize="16"
                                           Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding IsDownloaded}"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Download progress -->
                <StackPanel x:Name="DownloadPanel" Visibility="Collapsed" Spacing="6">
                    <TextBlock x:Name="DownloadStatusText"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <ProgressBar x:Name="DownloadProgress"
                                 Minimum="0" Maximum="100"/>
            <Button x:Name="CancelDownloadButton"
                            HorizontalAlignment="Right"
                            Click="CancelDownload_Click"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Page 2: Recording -->
        <Grid x:Name="RecordingPage" Grid.Row="1" Visibility="Collapsed" Padding="16,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Model name + duration -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="ActiveModelName" Grid.Column="0"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock x:Name="RecordingDuration" Grid.Column="1"
                           Text="0:00"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </Grid>

            <!-- Record + Save buttons -->
            <StackPanel Grid.Row="1" Orientation="Horizontal"
                        HorizontalAlignment="Center" Spacing="12" Margin="0,12">
                <Button x:Name="RecordButton"
                        Width="48" Height="48"
                        CornerRadius="24"
                        Click="Record_Click">
                    <FontIcon x:Name="RecordIcon" Glyph="&#xE720;" FontSize="20"/>
                </Button>
                    <Button x:Name="SaveNoteButton"
                        Visibility="Collapsed"
                        Click="SaveNote_Click"/>
            </StackPanel>

            <!-- Transcription -->
            <ScrollViewer Grid.Row="2" Margin="0,8,0,0">
                <StackPanel Spacing="4">
                    <TextBlock x:Name="TranscriptionText"
                               TextWrapping="Wrap"
                               FontSize="14"/>
                    <TextBlock x:Name="PartialText"
                               TextWrapping="Wrap"
                               FontSize="14"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               FontStyle="Italic"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Status bar -->
        <Grid Grid.Row="2" Padding="12,6" Background="Transparent">
            <TextBlock x:Name="StatusText"
                       HorizontalAlignment="Center"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
        </Grid>
    </Grid>
</Window>
