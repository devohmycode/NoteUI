<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="NoteUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NoteUI">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <FontFamily x:Key="GeistRegular">Assets/Fonts/Geist-Regular.otf#Geist</FontFamily>
            <FontFamily x:Key="GeistMedium">Assets/Fonts/Geist-Medium.otf#Geist Medium</FontFamily>
            <FontFamily x:Key="GeistBold">Assets/Fonts/Geist-Bold.otf#Geist Bold</FontFamily>
            <FontFamily x:Key="InterRegular">Assets/Fonts/Inter-Regular.ttf#Inter</FontFamily>
            <FontFamily x:Key="InterMedium">Assets/Fonts/Inter-Medium.ttf#Inter Medium</FontFamily>
            <FontFamily x:Key="InterBold">Assets/Fonts/Inter-Bold.ttf#Inter Bold</FontFamily>
            <FontFamily x:Key="JetBrainsMonoRegular">Assets/Fonts/JetBrainsMono-Regular.ttf#JetBrains Mono</FontFamily>
            <FontFamily x:Key="JetBrainsMonoMedium">Assets/Fonts/JetBrainsMono-Medium.ttf#JetBrains Mono Medium</FontFamily>
            <FontFamily x:Key="JetBrainsMonoBold">Assets/Fonts/JetBrainsMono-Bold.ttf#JetBrains Mono Bold</FontFamily>
            <FontFamily x:Key="ContentControlThemeFontFamily">Assets/Fonts/Geist-Regular.otf#Geist</FontFamily>
            <local:ColorToBrushConverter x:Key="ColorToBrush"/>
            <LinearGradientBrush x:Key="AccentLinearDownGradientBrush"
                                 StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#60CDFE" Offset="0"/>
                <GradientStop Color="#0078D4" Offset="1"/>
            </LinearGradientBrush>
        </ResourceDictionary>
    </Application.Resources>
</Application>
