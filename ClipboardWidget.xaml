<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="NoteUI.ClipboardWidget"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Clipboard">
    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Drag bar at the top -->
        <Grid x:Name="DragBar" Background="Transparent"
              Height="14" VerticalAlignment="Top"
              PointerPressed="DragBar_PointerPressed"
              PointerMoved="DragBar_PointerMoved"
              PointerReleased="DragBar_PointerReleased"
              Canvas.ZIndex="1"/>

        <!-- Content -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="6" Margin="0,6,0,0">
            <StackPanel x:Name="ContentPanel" Spacing="2"/>
        </ScrollViewer>

        <!-- Footer: opacity slider + compact toggle + resize grip -->
        <Grid Grid.Row="1" Padding="8,2,4,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <FontIcon Grid.Column="0" Glyph="&#xE7A6;" FontSize="10" Opacity="0.4"
                      VerticalAlignment="Center" Margin="0,0,4,0"/>
            <Slider x:Name="OpacitySlider" Grid.Column="1"
                    Minimum="30" Maximum="100" Value="100"
                    Height="24" VerticalAlignment="Center"
                    ValueChanged="OpacitySlider_ValueChanged"/>
            <Button x:Name="CompactToggle" Grid.Column="2"
                    Background="Transparent" BorderThickness="0"
                    Padding="6,4" CornerRadius="4"
                    Click="CompactToggle_Click"
                    VerticalAlignment="Center">
                <FontIcon x:Name="CompactIcon" Glyph="&#xE14C;" FontSize="11"/>
            </Button>
            <!-- Resize grip -->
            <Grid x:Name="ResizeGrip" Grid.Column="3"
                  Width="16" Height="16"
                  VerticalAlignment="Bottom"
                  PointerPressed="ResizeGrip_PointerPressed"
                  PointerMoved="ResizeGrip_PointerMoved"
                  PointerReleased="ResizeGrip_PointerReleased">
                <FontIcon Glyph="&#xE740;" FontSize="10" Opacity="0.3"
                          HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
