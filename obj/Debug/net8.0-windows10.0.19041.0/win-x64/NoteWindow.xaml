<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="NoteUI.NoteWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Note">

    <Grid x:ConnectionId='2' x:Name="RootGrid"                           >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Title bar (colored) -->
        <Grid x:ConnectionId='3' x:Name="TitleBarGrid" Grid.Row="0" Height="40" Padding="4,0">
            <Grid x:ConnectionId='9' x:Name="DragBar" Background="Transparent"
                                                         
                                                     
                                                           />

            <Button x:ConnectionId='10' x:Name="MenuButton" HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Background="Transparent" BorderThickness="0"
                    Padding="8,6"                   
                    ToolTipService.ToolTip="Menu">
                <FontIcon Glyph="&#xE712;" FontSize="14" Foreground="Black"/>
            </Button>

            <!-- Inline editable title -->
            <TextBlock x:ConnectionId='11' x:Name="TitleText" Text="Sans titre"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="13" Foreground="Black"
                       IsHitTestVisible="True"
                                                
                       TextTrimming="CharacterEllipsis" MaxWidth="200"/>
            <TextBox x:ConnectionId='12' x:Name="TitleEditBox"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     FontSize="13" Visibility="Collapsed"
                     MinWidth="120" MaxWidth="200"
                     Background="Transparent" BorderThickness="0"
                     Padding="6,4" TextAlignment="Center"
                                                       
                                                   />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        VerticalAlignment="Center" Spacing="0">
                <Button x:ConnectionId='13' Background="Transparent" BorderThickness="0"
                        Padding="8,6"                      
                        ToolTipService.ToolTip="Compacter">
                    <FontIcon x:ConnectionId='17' x:Name="CompactIcon" Glyph="&#xE70E;" FontSize="12" Foreground="Black"/>
                </Button>
                <Button x:ConnectionId='14' x:Name="PinButton"
                        Background="Transparent" BorderThickness="0"
                        Padding="8,6"                  
                        ToolTipService.ToolTip="&#201;pingler">
                    <FontIcon x:ConnectionId='16' x:Name="PinIcon" Glyph="&#xE718;" FontSize="12" Foreground="Black"/>
                </Button>
                <Button x:ConnectionId='15' Background="Transparent" BorderThickness="0"
                        Padding="8,6"                    
                        ToolTipService.ToolTip="Fermer">
                    <FontIcon Glyph="&#xE711;" FontSize="12" Foreground="Black"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Row 1: Rich text editor -->
        <RichEditBox x:ConnectionId='4' x:Name="NoteEditor" Grid.Row="1"
                     AcceptsReturn="True"
                     BorderThickness="0"
                     Background="Transparent"
                     CornerRadius="0"
                     Padding="12,4"
                                                         >
            <RichEditBox.Resources>
                <SolidColorBrush x:Key="TextControlBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent"/>
                <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent"/>
                <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent"/>
                <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent"/>
                <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent"/>
            </RichEditBox.Resources>
        </RichEditBox>

        <!-- Row 2: Status bar with Format (left) and Couleur (right) -->
        <Grid x:ConnectionId='5' x:Name="StatusBar" Grid.Row="2" Padding="4,2"
              BorderThickness="0,1,0,0"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:ConnectionId='6' x:Name="FormatButton" Grid.Column="0"
                    Background="Transparent" BorderThickness="0"
                    Padding="10,6"                     
                    ToolTipService.ToolTip="Format">
                <FontIcon Glyph="&#xE8D2;" FontSize="12"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </Button>

            <Button x:ConnectionId='7' x:Name="ColorButton" Grid.Column="2"
                    Background="Transparent" BorderThickness="0"
                    Padding="10,6"                    
                    ToolTipService.ToolTip="Couleur">
                <Ellipse x:ConnectionId='8' x:Name="ColorIndicator" Width="12" Height="12"/>
            </Button>
        </Grid>
    </Grid>
</Window>

