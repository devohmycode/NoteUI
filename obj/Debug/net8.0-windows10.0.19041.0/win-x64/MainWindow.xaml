<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="NoteUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Notes">

    <Grid x:ConnectionId='2' x:Name="RootGrid" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Custom title bar -->
        <Grid x:ConnectionId='3' x:Name="TitleBar" Grid.Row="0" Height="40" Padding="4,0">
            <Grid x:ConnectionId='6' x:Name="DragBar" Background="Transparent"
                                                         
                                                     
                                                           />

            <Button x:ConnectionId='7' HorizontalAlignment="Left" VerticalAlignment="Center"
                    Background="Transparent" BorderThickness="0"
                    Padding="10,6"                      
                    ToolTipService.ToolTip="Nouvelle note">
                <FontIcon Glyph="&#xE710;" FontSize="16"/>
            </Button>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        VerticalAlignment="Center" Spacing="0">
                <Button x:ConnectionId='8' Background="Transparent" BorderThickness="0"
                        Padding="10,6"                      
                        ToolTipService.ToolTip="Compacter">
                    <FontIcon x:ConnectionId='13' x:Name="CompactIcon" Glyph="&#xE70E;" FontSize="12"/>
                </Button>
                <Button x:ConnectionId='9' x:Name="PinButton" Background="Transparent" BorderThickness="0"
                        Padding="10,6"                  
                        ToolTipService.ToolTip="&#201;pingler">
                    <FontIcon x:ConnectionId='12' x:Name="PinIcon" Glyph="&#xE718;" FontSize="12"/>
                </Button>
                <Button x:ConnectionId='10' Background="Transparent" BorderThickness="0"
                        Padding="10,6"                       
                        ToolTipService.ToolTip="Param&#232;tres">
                    <FontIcon Glyph="&#xE713;" FontSize="14"/>
                </Button>
                <Button x:ConnectionId='11' Background="Transparent" BorderThickness="0"
                        Padding="10,6"                    
                        ToolTipService.ToolTip="Fermer">
                    <FontIcon Glyph="&#xE711;" FontSize="12"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Row 1: Title -->
        <TextBlock Grid.Row="1" Text="Notes"
                   FontSize="22" FontWeight="Bold"
                   Margin="16,0,16,8"/>

        <!-- Row 2: Search -->
        <Grid Grid.Row="2" Margin="12,0,12,8">
            <TextBox x:ConnectionId='5' x:Name="SearchBox"
                     PlaceholderText="Rechercher..."
                                                        
                     CornerRadius="4"
                     Padding="8,6,30,6">
                <TextBox.Resources>
                    <SolidColorBrush x:Key="TextControlBackground" Color="#08000000"/>
                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#0F000000"/>
                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#0F000000"/>
                    <SolidColorBrush x:Key="TextControlBorderBrush" Color="#15000000"/>
                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#20000000"/>
                </TextBox.Resources>
            </TextBox>
            <FontIcon Glyph="&#xE721;" FontSize="14"
                      HorizontalAlignment="Right" VerticalAlignment="Center"
                      Margin="0,0,10,0" IsHitTestVisible="False"
                      Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
        </Grid>

        <!-- Row 3: Notes list -->
        <ScrollViewer Grid.Row="3" Padding="12,0,12,12"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel x:ConnectionId='4' x:Name="NotesList" Spacing="8"/>
        </ScrollViewer>
    </Grid>
</Window>

